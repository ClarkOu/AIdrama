# LLM 配置
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o

# Seedream 图片生成（火山方舟）
SEEDREAM_API_KEY=your_seedream_api_key_here
SEEDREAM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# Seedance 视频生成（火山方舟）
SEEDANCE_API_KEY=your_seedance_api_key_here
SEEDANCE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 数据库（默认 SQLite，生产换 PostgreSQL）
# DATABASE_URL=postgresql://user:password@localhost:5432/aidrama

# Redis（Celery 任务队列，本地 MVP 可选）
# REDIS_URL=redis://localhost:6379/0

# 并发控制
MAX_CONCURRENT_VIDEO_TASKS=10
VIDEO_RETRY_LIMIT=3
